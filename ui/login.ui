   <string notr="true">QWidget {
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 14px;
    color: #f3ead8;
}


/* ============================= */
/* 背景图片（保留你的原图） */
/* ============================= */

QWidget#Form {
    border-image: url(resources/images/loginPage.png) 0 0 0 0 stretch stretch;
}


/* ============================= */
/* 中间半透明卡片 */
/* ============================= */

QFrame#frame {
    background-color: transparent;
    border: none;
    border-radius: 0px;
}


/* ============================= */
/* 标题 */
/* ============================= */

QLabel#label,
QLabel#label_4 {
    font-size: 28px;
    font-weight: bold;
    color: #ff6b81;
    background: transparent;
}


/* ============================= */
/* 表单标签 */
/* ============================= */

QLabel#label_2,
QLabel#label_3 {
    font-size: 15px;
    color: #736451;
    background: transparent;
}


/* ============================= */
/* 输入框 */
/* ============================= */

QLineEdit {
    background-color: rgba(255,255,255,235);
    color: #4b4439;
    border: 1px solid #c3cd9b;
    border-radius: 8px;
    padding: 6px 10px;
    min-height: 32px;
}

/* focus */
QLineEdit:focus {
    border: 2px solid #d4dfac;
    background-color: #ffffff;
}


/* ============================= */
/* Login 按钮 */
/* ============================= */

QPushButton#pushButton {
    background-color: #736451;
    color: white;
    border-radius: 10px;
    font-size: 15px;
    font-weight: bold;
    min-height: 36px;
    border: none;
}

/* hover */
QPushButton#pushButton:hover {
    background-color: #a79782;
}

/* pressed */
QPushButton#pushButton:pressed {
    background-color: #a79782;
}


/* ============================= */
/* Register 按钮 */
/* ============================= */

QPushButton#pushButton_2 {
    background: transparent;
    color: #736451;
    border: none;
}

/* hover */
QPushButton#pushButton_2:hover {
    text-decoration: underline;
    color: #d4dfac;
}


/* ============================= */
/* Forgot password */
/* ============================= */

QPushButton#pushButton_3 {
    background: transparent;
    color: #736451;
    border: none;
}

/* hover */
QPushButton#pushButton_3:hover {
    color: #d4dfac;
}


/* ============================= */
/* 提示信息（错误提示） */
/* ============================= */

QLabel#label_5 {
    color: #e63946;
    font-size: 13px;
}</string>
