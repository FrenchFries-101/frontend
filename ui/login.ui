  <property name="styleSheet">
   <string notr="true">QWidget {
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 14px;
    color: #444444;
}


/* ============================= */
/* 背景图片（保留你的原图） */
/* ============================= */

QWidget#Form {
    border-image: url(resources/images/login-picture2.jpg) 0 0 0 0 stretch stretch;
}


/* ============================= */
/* 中间半透明卡片 */
/* ============================= */

QFrame#frame {
    background-color: rgba(255,255,255,190);
    border-radius: 15px;
}


/* ============================= */
/* 标题 */
/* ============================= */

QLabel#label,
QLabel#label_4 {
    font-size: 28px;
    font-weight: bold;
    color: #ff6b81;
    background: transparent;
}


/* ============================= */
/* 表单标签 */
/* ============================= */

QLabel#label_2,
QLabel#label_3 {
    font-size: 15px;
    color: #666666;
    background: transparent;
}


/* ============================= */
/* 输入框 */
/* ============================= */

QLineEdit {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 6px 10px;
    min-height: 32px;
}

/* focus */
QLineEdit:focus {
    border: 2px solid #ff6b81;
    background-color: #fffafa;
}


/* ============================= */
/* Login 按钮 */
/* ============================= */

QPushButton#pushButton {
    background-color: #ff6b81;
    color: white;
    border-radius: 10px;
    font-size: 15px;
    font-weight: bold;
    min-height: 36px;
    border: none;
}

/* hover */
QPushButton#pushButton:hover {
    background-color: #ff4f70;
}

/* pressed */
QPushButton#pushButton:pressed {
    background-color: #e8435f;
}


/* ============================= */
/* Register 按钮 */
/* ============================= */

QPushButton#pushButton_2 {
    background: transparent;
    color: #ff6b81;
    border: none;
}

/* hover */
QPushButton#pushButton_2:hover {
    text-decoration: underline;
    color: #ff4f70;
}


/* ============================= */
/* Forgot password */
/* ============================= */

QPushButton#pushButton_3 {
    background: transparent;
    color: #999999;
    border: none;
}

/* hover */
QPushButton#pushButton_3:hover {
    color: #ff6b81;
}


/* ============================= */
/* 提示信息（错误提示） */
/* ============================= */

QLabel#label_5 {
    color: #e63946;
    font-size: 13px;
}</string>
