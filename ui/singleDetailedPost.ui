   <string notr="true">


/* SingleDetailedPost - Warm Theme */
QWidget#post_simple{
    background: #fffaf5;
    border: 1px solid #ead8c8;
    border-radius: 12px;
    padding: 12px;
}

QWidget#post_simple QLabel#post_title{
    font-size: 19px;
    font-weight: 700;
    color: #6b4f3b;
}

QWidget#post_simple QLabel#auther_time{
    font-size: 12px;
    color: #9b8c80;
}

QWidget#post_simple QLabel#contents{
    font-size: 15px;
    color: #5f4b3f;
    padding-top: 4px;
    padding-bottom: 4px;
}

QWidget#post_simple QLabel#post_likes{
    font-size: 12px;
    color: #e07a2f;
    font-weight: 600;
}

QWidget#post_simple QPushButton#like_button{
    border: 1px solid #ead8c8;
    background: #fff3e8;
    border-radius: 8px;
}
QWidget#post_simple QPushButton#like_button:hover{
    background: #ffe9d6;
    border: 1px solid #f2c39d;
}
QWidget#post_simple QPushButton#like_button:pressed{
    background: #ffdcbf;
}


