    <string notr="true">
 /* SingleReply - Warm Theme */
 QWidget#Form{
     background-color: #fffaf5;
     border-radius: 12px;
     border: 1px solid #ead8c8;
     padding: 10px;
 }
 QWidget#Form:hover{
     background-color: #fff3e8;
     border: 1px solid #f2c39d;
}

QWidget#Form QLabel#name{
    font-size: 13px;
    font-weight: 700;
    color: #6b4f3b;
}
QWidget#Form:hover QLabel#name{
    color: #f28d40;
}

QWidget#Form QLabel#time{
    font-size: 11px;
    color: #9b8c80;
}
QWidget#Form QLabel#label_content{
    font-size: 14px;
    color: #5f4b3f;
    padding-top: 4px;
    padding-bottom: 4px;
}
QWidget#Form QLabel#like{
    font-size: 12px;
    color: #e07a2f;
    font-weight: 600;
}

QWidget#Form *{
    background: transparent;
}

</string>
