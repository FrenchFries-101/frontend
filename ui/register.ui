  <property name="styleSheet">
   <string notr="true">QWidget {
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 14px;
    color: #f3ead8;
}


/* ============================= */
/* 背景图片 */
/* ============================= */

QWidget#Form {
    border-image: none;
}


/* ============================= */
/* 中间半透明卡片 */
/* ============================= */

QFrame#frame {
    background-color: rgba(255,255,255,190);
    border-radius: 15px;
}


/* ============================= */
/* 让布局容器透明 */
/* ============================= */

QWidget#verticalLayoutWidget {
    background: transparent;
}


/* ============================= */
/* LOGO标题 */
/* ============================= */

QLabel#label,
QLabel#label_4 {
    font-size: 30px;
    font-weight: bold;
    color: #fff8ea;
    background: transparent;
}


/* ============================= */
/* 表单标签 */
/* ============================= */

QLabel#label_2,
QLabel#label_3 {
    font-size: 15px;
    color: #666666;
    background: transparent;
}


/* ============================= */
/* 输入框 */
/* ============================= */

QLineEdit {
    background-color: rgba(255,255,255,235);
    color: #4b4439;
    border: 1px solid #c3cd9b;
    border-radius: 8px;
    padding: 6px 10px;
    min-height: 32px;
}

/* 输入框获得焦点 */
QLineEdit:focus {
    border: 2px solid #d4dfac;
    background-color: #ffffff;
}


/* ============================= */
/* Login 按钮 */
/* ============================= */

QPushButton#pushButton {
    background-color: #ff6b81;
    color: white;
    border-radius: 10px;
    font-size: 15px;
    font-weight: bold;
    min-height: 36px;
    border: none;
}

/* Hover */
QPushButton#pushButton:hover {
    background-color: #ff4f70;
}

/* 点击 */
QPushButton#pushButton:pressed {
    background-color: #e8435f;
}


/* ============================= */
/* Register 按钮 */
/* ============================= */

QPushButton#pushButton_2 {
    background: transparent;
    color: #fff6df;
    border: none;
}

/* hover */
QPushButton#pushButton_2:hover {
    text-decoration: underline;
    color: #d4dfac;
}


/* ============================= */
/* Forgot password */
/* ============================= */

QPushButton#pushButton_3 {
    background: transparent;
    color: #999999;
    border: none;
}

/* hover */
QPushButton#pushButton_3:hover {
    color: #ff6b81;
}


/* ============================= */
/* 提示信息（错误提示） */
/* ============================= */

QLabel#label_5 {
    color: #e63946;
    font-size: 13px;
}</string>
