  <property name="styleSheet">
   <string notr="true">/* 整体窗口背景 */
QWidget#Form{
        background:qlineargradient(
        x1:0, y1:0,
        x2:1, y2:1,
        stop:0 #727272,
        stop:1 #ffd6e0
    );
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
}


/* 左侧侧边栏 */
QWidget#horizontalLayoutWidget{
    background-color: transparent;
}


/* Logo */
QLabel#label{
    font-size: 26px;
    font-weight: bold;
    color: #ff6b81;
    padding: 20px;
}


/* 左侧按钮统一样式 */
QPushButton{
    background-color: transparent;
    border: none;

    font-family: &quot;Segoe UI Semibold&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 15px;
    font-weight: bold;

    padding: 12px 20px;
    margin-left: 10px;
    margin-right: 10px;

    text-align: left;
    color: #444;

    border-radius: 10px;
}


QPushButton:hover{
    background-color: #ffe4ea;
    color: #ff4f70;
}


QPushButton:pressed{
    background-color: #ffd2dc;
}


/* 当前选中按钮（可手动加）*/
QPushButton:checked{
    background-color: #ffccd5;
    color: #d6336c;
}


/* 右侧页面区域 */
QWidget#PageArea{
    background-color: #ffffff;
    border-radius: 12px;
    margin: 10px;
}


/* 页面文字 */
QLabel#label_2,
QLabel#label_3,
QLabel#label_4{
    font-size: 22px;
    color: #444;
}


/* stackedWidget背景 */
QStackedWidget{
    background-color: transparent;
}</string>
