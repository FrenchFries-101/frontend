  <property name="styleSheet">
   <string notr="true">/* ================= 全局背景 ================= */
QWidget#Form{
    background:qlineargradient(
        x1:0, y1:0,
        x2:1, y2:1,
        stop:0 #fff6ea,
        stop:1 #fdf1e6
    );
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
}


/* ================= Logo ================= */
QLabel#label{
    font-size: 26px;
    font-weight: bold;
    color: #f28d40;   /* 主橙色 */
    padding: 20px;
}


/* ================= 左侧按钮 ================= */
QPushButton{
    background-color: transparent;
    border: none;

    font-family: &quot;Segoe UI Semibold&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 15px;
    font-weight: bold;

    padding: 12px 20px;
    margin-left: 10px;
    margin-right: 10px;

    text-align: left;
    color: #6b5e55;

    border-radius: 10px;
}

QPushButton:hover{
    background-color: #fff0e3;
    color: #f28d40;
}

QPushButton:pressed{
    background-color: #ffe0cc;
}

QPushButton:checked{
    background-color: #ffe8d6;
    color: #f28d40;
}


/* ================= 右侧主区域 ================= */
QWidget#PageArea{
    background-color: #ffffff;
    border-radius: 12px;
    margin: 10px;
}


/* ================= 标题文字 ================= */
QLabel#label_2,
QLabel#label_3,
QLabel#label_4{
    font-size: 22px;
    color: #b3886b;   /* 木质棕 */
}


/* ================= 滚动区域 ================= */
QScrollArea, 
#scrollAreaWidgetContents, 
#scrollAreaWidgetContents_2, 
#scrollAreaWidgetContents_3 {
    background-color: #ffffff;
    border: none;
}


/* ================= 滚动条 ================= */
QScrollBar:vertical {
    border: none;
    background: #dfe0df;
    width: 6px;
    border-radius: 3px;
}

QScrollBar::handle:vertical {
    background: #b3886b;
    border-radius: 3px;
}

QScrollBar::handle:vertical:hover {
    background: #f28d40;
}


/* ================= 左侧书籍列表 ================= */
#book_scroll QPushButton {
    background-color: transparent;
    border: none;
    color: #7a6a5f;
    padding: 12px 5px;
    font-size: 14px;
    text-align: center;
    border-bottom: 1px solid #dfe0df;
}

#book_scroll QPushButton:hover {
    background-color: #fff0e3;
    color: #f28d40;
}

#book_scroll QPushButton:checked {
    background-color: #ffffff;
    color: #f28d40;
    font-weight: bold;
    border-left: 4px solid #f28d40;
}


/* ================= 卡片 ================= */
QFrame#frame, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #dfe0df;
    border-radius: 12px;
    margin: 5px 10px;
}

QFrame#frame:hover, QFrame#frame_3:hover {
    border: 1px solid #f28d40;
    background-color: #fffaf5;
}


/* ================= 卡片标题 ================= */
QLabel#label_7, QLabel#label_10 {
    font-weight: bold;
    font-size: 16px;
    color: #5c5047;
}

/* 副标题 */
QLabel#label_8, QLabel#label_11 {
    font-size: 13px;
    color: #9b8c80;
}


/* ================= 标签 ================= */
QLabel#label_5, QLabel#label_9 {
    color: #f28d40;
    background-color: #fff3e8;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: bold;
}


/* ================= 测试卡片 ================= */
QFrame#test_card {
    background-color: white;
    border-radius: 10px;
    border: 1px solid #dfe0df;
    padding: 10px;
}

QFrame#test_card:hover {
    border: 1px solid #f28d40;
    background-color: #fff3e8;
}


/* ================= 进度条 ================= */
QProgressBar {
    border: none;
    background-color: #f0f0f0;
    border-radius: 6px;
    text-align: center;
}

QProgressBar::chunk {
    background-color: #f28d40;
    border-radius: 6px;
}


/* ================= 头像 ================= */
QLabel#label_4 {
    background-color: #fff3e8;
    border-radius: 50px;
    border: 2px solid #f28d40;
    padding: 6px;
}


/* ================= 小标签 ================= */
QLabel#label_13 {
    font-size: 14px;
    font-weight: bold;
    color: #f28d40;

    background-color: #fff3e8;
    border-radius: 10px;

    padding: 4px 10px;
}

QWidget#SideBar{
    background-color: #f2e2d3;
    border-right: 1px solid #e5cdb8;
    border-radius: 0px;
    margin: 0px;
}

QWidget#widget_5{
    background-color: #f2e2d3;   /* 比主背景更深一点 */
    border: none;
    border-radius: 0px;
    margin: 0px;
}


QWidget#PageArea{
    background-color: #fffaf5;
    border: none;
    border-radius: 0px;
    margin: 0px;
}

/* Tree 导航 */
QTreeWidget#navTree{
    background: transparent;
    border: none;
    outline: none;
    font-family: &quot;Segoe UI Semibold&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 15px;
    font-weight: bold;
    color: #6b5e55;
}

QTreeWidget#navTree::item{
    height: 34px;
    padding-left: 8px;
}

QTreeWidget#navTree::item:hover{
    background: #fff0e3;
    color: #f28d40;
}

QTreeWidget#navTree::item:selected{
    background: #ffe8d6;
    color: #f28d40;
}

QWidget#widget_4{
    background-color: #fff3e8;
    border: 1px solid #efcfb7;
    border-radius: 8px;
}

QLabel#streakLabel{
    font-size: 14px;
    font-weight: 600;
    color: #7a5c45;
    padding: 4px 8px;
}

QLabel#coinValueLabel{
    font-size: 15px;
    font-weight: bold;
    color: #f28d40;
    padding-right: 10px;
}

QLabel#label, QLabel#label_4, QLabel#label_13{
    background: transparent;
}

</string>
